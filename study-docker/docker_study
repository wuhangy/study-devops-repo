###docker compose 用一个 YAML 文件定义所有服务，一条命令启动所有容器。
###################################docker-compose.yml############################################
##当我要使用到很多容器的时候，比如说前端后端 数据库一起搭建的时候，需要一个一个构建然后在进行run，此时就会比较麻烦我直接使用docker compose yaml文件一键部署
##一个yaml 文件
# Docker Compose 文件版本
version: '3.8'

# 所有服务（容器）的定义
services:
  # MySQL 数据库服务
  mysql:
    image: mysql:8.0           # 使用官方 MySQL 8.0 镜像
    environment:                # 环境变量配置
      MYSQL_ROOT_PASSWORD: 123456  # root 用户密码
    volumes:                    # 数据持久化
      - mysql-data:/var/lib/mysql  # 卷名:容器内路径

  # Redis 缓存服务
  redis:
    image: redis:alpine        # 轻量级 Redis 镜像

  # Python 后端应用
  python-app:
    build: .                   # 使用当前目录的 Dockerfile 构建
    ports:                     # 端口映射
      - "8000:8000"           # 宿主机:容器
    depends_on:                # 启动顺序依赖
      - mysql
      - redis

  # Nginx 反向代理
  nginx:
    image: nginx               # 使用官方 Nginx 镜像
    ports:
      - "80:80"               # HTTP 入口
    volumes:                   # 配置文件挂载
      - ./nginx.conf:/etc/nginx/nginx.conf
    depends_on:
      - python-app

# 数据卷定义（用于持久化存储）
volumes:
  mysql-da  ta:                  # 声明 mysql-data 这个卷


